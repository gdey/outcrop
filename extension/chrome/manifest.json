{
  "manifest_version": 3,
  "name": "Outcrop",
  "version": "0.1.2",
  "description": "Clip a region of a webpage into a markdown-notes folder.",
  "icons": {
    "16": "icons/16.png",
    "32": "icons/32.png",
    "48": "icons/48.png",
    "128": "icons/128.png"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "Outcrop",
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/16.png",
      "32": "icons/32.png"
    }
  },
  "options_ui": {
    "page": "options/options.html",
    "open_in_tab": true
  },
  "permissions": ["activeTab", "storage", "scripting", "notifications"],
  "host_permissions": [
    "http://127.0.0.1:7878/*",
    "http://localhost:7878/*"
  ],
  "minimum_chrome_version": "120"
}
