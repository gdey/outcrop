{
  "manifest_version": 3,
  "name": "Outcrop",
  "version": "0.1.0",
  "description": "Clip a region of a webpage into an Obsidian vault.",
  "icons": {
    "16": "icons/16.png",
    "32": "icons/32.png",
    "48": "icons/48.png",
    "128": "icons/128.png"
  },
  "background": {
    "scripts": ["background.js"],
    "type": "module"
  },
  "action": {
    "default_title": "Outcrop",
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/16.png",
      "32": "icons/32.png"
    }
  },
  "options_ui": {
    "page": "options/options.html",
    "open_in_tab": true
  },
  "permissions": ["activeTab", "storage", "scripting", "notifications"],
  "host_permissions": [
    "http://127.0.0.1:7878/*",
    "http://localhost:7878/*"
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "outcrop@gdey",
      "strict_min_version": "140.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  }
}
